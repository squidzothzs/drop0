# Copy to .env.local and fill in from your Supabase project
# (Dashboard → Project Settings → API). Also set these in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# server-only — never prefixed NEXT_PUBLIC, never shipped to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# password for the /admin page
ADMIN_PASSWORD=choose-a-strong-password
